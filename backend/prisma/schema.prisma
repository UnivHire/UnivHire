// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String?
  name         String
  role         String        // 'CANDIDATE', 'HR', 'ADMIN'
  university   String?
  avatar       String?

  // Extended profile fields (shared candidate + HR)
  phone            String?
  headline         String?
  about            String?
  resumeUrl        String?
  portfolioUrl     String?
  experienceLevel  String?
  availability     String?
  skills           String?   // comma-separated
  preferredRole    String?
  location         String?

  // HR-specific profile fields
  designation      String?
  department       String?
  website          String?
  linkedin         String?
  bio              String?

  // Settings stored as JSON strings
  notificationSettings String?
  preferences          String?

  createdAt    DateTime      @default(now())
  jobsPosted   Job[]
  applications Application[]
  savedJobs    SavedJob[]
  invitesSent  Invite[]      @relation("InviteSender")
}

model Job {
  id                  String        @id @default(uuid())
  hrId                String
  hr                  User          @relation(fields: [hrId], references: [id])
  title               String
  organizationName    String        @default("")
  description         String
  location            String
  jobType             String        // 'FULL_TIME', 'PART_TIME', 'CONTRACT', 'INTERNSHIP', 'TEMPORARY'
  workplaceType       String        @default("ON_SITE")
  seniorityLevel      String        @default("NOT_APPLICABLE")
  jobFunction         String        @default("")
  industry            String        @default("")
  experienceYears     Int           @default(0)
  requiredSkills      String        @default("")
  screeningQuestions  String        @default("")
  applicationMode     String        @default("PLATFORM")
  applicationEmail    String        @default("")
  requireResume       Boolean       @default(true)
  externalApplyUrl    String        @default("")
  status              String        @default("OPEN")
  isVerified          Boolean       @default(false)
  createdAt           DateTime      @default(now())
  applications        Application[]
  savedBy             SavedJob[]
}

model Application {
  id               String   @id @default(uuid())
  jobId            String
  job              Job      @relation(fields: [jobId], references: [id])
  candidateId      String
  candidate        User     @relation(fields: [candidateId], references: [id])
  candidatePhone   String?
  candidateAddress String?
  currentLocation  String?
  resumeUrl        String?
  status           String   @default("PENDING")
  appliedAt        DateTime @default(now())

  @@unique([jobId, candidateId])
}

model SavedJob {
  candidateId String
  candidate   User      @relation(fields: [candidateId], references: [id])
  jobId       String
  job         Job       @relation(fields: [jobId], references: [id])
  savedAt     DateTime  @default(now())

  @@id([candidateId, jobId])
}

model Invite {
  id        String   @id @default(uuid())
  token     String   @unique @default(uuid())
  email     String
  role      String   @default("HR")
  senderId  String
  sender    User     @relation("InviteSender", fields: [senderId], references: [id])
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}
