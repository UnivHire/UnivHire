// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  role         String        // 'CANDIDATE', 'HR', 'ADMIN'
  university   String?       // Make sure optional
  createdAt    DateTime      @default(now())
  jobsPosted   Job[]         // Only if role == 'HR'
  applications Application[] // Only if role == 'CANDIDATE'
  savedJobs    SavedJob[]
}

model Job {
  id          String        @id @default(uuid())
  hrId        String
  hr          User          @relation(fields: [hrId], references: [id])
  title       String
  description String
  location    String
  jobType     String        // 'FULL_TIME', 'INTERNSHIP', 'CONTRACT'
  status      String        @default("OPEN") // 'OPEN', 'CLOSED'
  createdAt   DateTime      @default(now())
  applications Application[]
  savedBy      SavedJob[]
}

model Application {
  id          String   @id @default(uuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id])
  candidateId String
  candidate   User     @relation(fields: [candidateId], references: [id])
  resumeUrl   String?
  status      String   @default("PENDING") // 'PENDING', 'REVIEWED', 'REJECTED', 'ACCEPTED'
  appliedAt   DateTime @default(now())

  @@unique([jobId, candidateId]) // A user can only apply once to a job
}

model SavedJob {
  candidateId String
  candidate   User   @relation(fields: [candidateId], references: [id])
  jobId       String
  job         Job    @relation(fields: [jobId], references: [id])

  @@id([candidateId, jobId]) // Composite primary key
}
