// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  role         String        // 'CANDIDATE', 'HR', 'ADMIN'
  university   String?       // Make sure optional
  createdAt    DateTime      @default(now())
  jobsPosted   Job[]         // Only if role == 'HR'
  applications Application[] // Only if role == 'CANDIDATE'
  savedJobs    SavedJob[]
}

model Job {
  id                  String        @id @default(uuid())
  hrId                String
  hr                  User          @relation(fields: [hrId], references: [id])
  title               String
  organizationName    String        @default("")
  description         String
  location            String
  jobType             String        // 'FULL_TIME', 'PART_TIME', 'CONTRACT', 'INTERNSHIP', 'TEMPORARY'
  workplaceType       String        @default("ON_SITE") // 'ON_SITE', 'REMOTE', 'HYBRID'
  seniorityLevel      String        @default("NOT_APPLICABLE") // 'NOT_APPLICABLE', 'INTERNSHIP', 'ENTRY', 'ASSOCIATE', 'MID_SENIOR', 'DIRECTOR', 'EXECUTIVE'
  jobFunction         String        @default("") // comma-separated e.g. "Administrative,Education"
  industry            String        @default("") // comma-separated e.g. "Higher Education"
  experienceYears     Int           @default(0)
  requiredSkills      String        @default("") // comma-separated
  screeningQuestions  String        @default("") // JSON array string
  applicationMode     String        @default("PLATFORM") // 'PLATFORM', 'EXTERNAL'
  applicationEmail    String        @default("")
  requireResume       Boolean       @default(true)
  externalApplyUrl    String        @default("")
  status              String        @default("OPEN") // 'OPEN', 'CLOSED'
  createdAt           DateTime      @default(now())
  applications        Application[]
  savedBy             SavedJob[]
}

model Application {
  id          String   @id @default(uuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id])
  candidateId String
  candidate   User     @relation(fields: [candidateId], references: [id])
  candidatePhone String?
  candidateAddress String?
  currentLocation String?
  resumeUrl   String?
  status      String   @default("PENDING") // 'PENDING', 'REVIEWED', 'REJECTED', 'ACCEPTED'
  appliedAt   DateTime @default(now())

  @@unique([jobId, candidateId]) // A user can only apply once to a job
}

model SavedJob {
  candidateId String
  candidate   User   @relation(fields: [candidateId], references: [id])
  jobId       String
  job         Job    @relation(fields: [jobId], references: [id])

  @@id([candidateId, jobId]) // Composite primary key
}
